PORT=3000
NODE_ENV=development

CORS_ORIGIN=http://localhost:5173

JWT_SECRET=change_me
JWT_EXPIRES_IN=7d

DATABASE_URL=postgresql://devmind:devmind_password@localhost:5432/devmind_db
# Pon DATABASE_SSL=true solo si tu proveedor de PostgreSQL exige SSL (Neon, Supabase, Render externo). Railway por red interna: false.
DATABASE_SSL=false

# El ZIP se procesa en memoria (multer memoryStorage). En una instancia pequeña
# de despliegue (512 MB - 1 GB) un valor alto puede provocar OOM. En producción
# se recomienda 25-50. En local puedes subirlo si necesitas probar ZIPs grandes.
MAX_ZIP_SIZE_MB=25
MAX_ZIP_UNCOMPRESSED_SIZE_MB=200

AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MINUTES=15

ASK_RATE_LIMIT_MAX=20
ASK_RATE_LIMIT_WINDOW_MINUTES=15

UPLOAD_RATE_LIMIT_MAX=10
UPLOAD_RATE_LIMIT_WINDOW_MINUTES=60

INDEXING_DELAY_BETWEEN_CHUNKS_MS=1000

GUEST_TTL_HOURS=24

EMBEDDING_MAX_RETRIES=3
EMBEDDING_RETRY_BASE_MS=1000

RAG_MAX_DISTANCE=1.0

GEMINI_API_KEY=tu_api_key